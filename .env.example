# ── CIMCO MDC Database (existing production MariaDB, READ-ONLY) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=cimco123
DB_NAME=MDC

# ── Backend API Server ──
SERVER_PORT=3002

# ── Dev server port (Vite) ──
DEV_PORT=5199

# ── CORS (optional, defaults to allow all in development) ──
# CORS_ORIGIN=http://localhost:5199

# ── Machine names (optional JSON, overrides built-in defaults) ──
# MACHINE_NAMES={"1":"CNC Lathe #1","2":"CNC Mill #2"}

# ── Shift Schedules (JSON array, defines available shifts) ──
SHIFT_SCHEDULES=[{"name":"Day Shift","start":"08:00","end":"20:00"},{"name":"Night Shift","start":"20:00","end":"08:00"}]
